+++ b/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.h
@@ -20,6 +20,7 @@
 #define DETACHED_SIG_FILE_EXTENSION     L".sig"
 
 #define EXTLINUX_CONF_PATH  L"boot\\extlinux\\extlinux.conf"
+#define UENV_CONF_PATH      L"boot\\loader\\uEnv.txt"
 
 #define BOOTMODE_DIRECT_STRING    L"bootmode=direct"
 #define BOOTMODE_GRUB_STRING      L"bootmode=grub"
@@ -52,6 +53,18 @@
 
 #define EXTLINUX_CBOOT_ARG  L"${cbootargs}"
 
+#define UENV_KEY_KERNEL_IMAGE     L"kernel_image="
+#define UENV_KEY_RAMDISK_IMAGE    L"ramdisk_image="
+#define UENV_KEY_FDTDIR           L"fdtdir="
+#define UENV_KEY_FDTFILE          L"fdtfile="
+#define UENV_KEY_BOOTARGS         L"bootargs="
+
+#define UENV_KEY_KERNEL_IMAGE2    L"kernel_image2="
+#define UENV_KEY_RAMDISK_IMAGE2   L"ramdisk_image2="
+#define UENV_KEY_FDTDIR2          L"fdtdir2="
+#define UENV_KEY_FDTFILE2         L"fdtfile2="
+#define UENV_KEY_BOOTARGS2        L"bootargs2="
+
 #define MAX_EXTLINUX_OPTIONS  10
 
 typedef struct {
diff --git a/Silicon/NVIDIA/Application/L4TLauncher/L4TRootfsValidation.c b/Silicon/NVIDIA/Application/L4TLauncher/L4TRootfsValidation.c
index aee2d832..d2a489dc 100644
--- a/Silicon/NVIDIA/Application/L4TLauncher/L4TRootfsValidation.c
+++ b/Silicon/NVIDIA/Application/L4TLauncher/L4TRootfsValidation.c
@@ -648,6 +648,10 @@ ValidateRootfsStatus (
     return EFI_SUCCESS;
   }
 
+  if (BootParams->BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+    BootParams->BootChain = ROOTFS_SLOT_A;
+  }
+
   if (BootParams->BootChain > ROOTFS_SLOT_B) {
     DEBUG ((
       DEBUG_ERROR,
@@ -697,6 +701,7 @@ ValidateRootfsStatus (
 
   // Set BootMode to RECOVERY if there is no more valid rootfs
   if (!IsValidRootfs ()) {
+
     BootParams->BootMode = NVIDIA_L4T_BOOTMODE_RECOVERY;
 
     // Clear the SR_RF when boot to recovery kernel.
@@ -721,7 +726,8 @@ ValidateRootfsStatus (
   }
 
   // Check redundancy level and validate rootfs status
-  switch (mRootfsInfo.RootfsVar[RF_REDUNDANCY].Value) {
+  if (BootParams->BootMode != NVIDIA_L4T_BOOTMODE_TORIZON) {
+    switch (mRootfsInfo.RootfsVar[RF_REDUNDANCY].Value) {
     case NVIDIA_OS_REDUNDANCY_BOOT_ONLY:
       // There is no rootfs B. Ensure to set rootfs slot to A.
       if (mRootfsInfo.CurrentSlot != ROOTFS_SLOT_A) {
@@ -845,6 +851,55 @@ ValidateRootfsStatus (
         mRootfsInfo.RootfsVar[RF_REDUNDANCY].Value
         ));
       break;
+    }
+  } else { /* Torizon Boot */
+    if (IsRootfsSlotBootable (mRootfsInfo.CurrentSlot)) {
+      if (BootParams->TorizonBootFlags & TORIZON_BOOTFLAGS_UPGRADE_AVAILABLE) {
+        Status = DecreaseRootfsRetryCount (mRootfsInfo.CurrentSlot);
+        if (EFI_ERROR (Status)) {
+          DEBUG ((
+            DEBUG_ERROR,
+            "%a: Failed to decrease the RetryCount of slot %d: %r\n",
+            __FUNCTION__,
+            mRootfsInfo.CurrentSlot,
+            Status
+            ));
+          goto Exit;
+        }
+      }
+    } else {
+      if (BootParams->TorizonBootFlags & TORIZON_BOOTFLAGS_UPGRADE_AVAILABLE) {
+        ErrorPrint (L"The boot counter has expired, setting the rollback flag\r\n");
+        Status = SetRetryCountTomRootfsInfo (mRootfsInfo.CurrentSlot, mRootfsInfo.RootfsVar[RF_RETRY_MAX].Value);
+        if (EFI_ERROR (Status)) {
+          DEBUG ((
+            DEBUG_ERROR,
+            "%a: Failed to reset the RetryCount of slot %d: %r\n",
+            __FUNCTION__,
+            mRootfsInfo.CurrentSlot,
+            Status
+            ));
+          goto Exit;
+        }
+        BootParams->TorizonBootFlags = TORIZON_BOOTFLAGS_ROLLBACK;
+        Status = gRT->SetVariable (
+                        TORIZON_BOOTFLAGS_VARIABLE_NAME,
+                        &gNVIDIAPublicVariableGuid,
+                        EFI_VARIABLE_BOOTSERVICE_ACCESS | EFI_VARIABLE_NON_VOLATILE | EFI_VARIABLE_RUNTIME_ACCESS,
+                        1,
+                        &BootParams->TorizonBootFlags);
+        if (EFI_ERROR (Status)) {
+          DEBUG ((
+            DEBUG_ERROR,
+            "%a: Failed to update Torizon BootFlags %x: %r\n",
+            __FUNCTION__,
+            BootParams->TorizonBootFlags,
+            Status
+            ));
+          goto Exit;
+        }
+      }
+    }
   }
 
 Exit:
