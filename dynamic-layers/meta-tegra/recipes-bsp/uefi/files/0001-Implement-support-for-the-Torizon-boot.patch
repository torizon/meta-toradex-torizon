--- a/Platform/NVIDIA/NVIDIA.common.dsc.inc
+++ b/Platform/NVIDIA/NVIDIA.common.dsc.inc
@@ -1080,6 +1080,7 @@ gEfiSecurityPkgTokenSpaceGuid.PcdSingleBootApplicationGuid|{ GUID("cbf481fb-b373
   gNVIDIATokenSpaceGuid.PcdOsChainStatusA|L"RootfsStatusSlotA"|gNVIDIAPublicVariableGuid|0x0|0|BS,NV,RT
   gNVIDIATokenSpaceGuid.PcdOsChainStatusB|L"RootfsStatusSlotB"|gNVIDIAPublicVariableGuid|0x0|0|BS,NV,RT
   gNVIDIATokenSpaceGuid.PcdL4TDefaultBootMode|L"L4TDefaultBootMode"|gNVIDIAPublicVariableGuid|0x00|0xFF|BS,NV,RT
+  gNVIDIATokenSpaceGuid.PcdTorizonBootFlags|L"TorizonBootFlags"|gNVIDIAPublicVariableGuid|0x00|0xFF|BS,NV,RT
   gNVIDIATokenSpaceGuid.PcdIpmiNetworkBootMode|L"IpmiNetworkBootMode"|gNVIDIAPublicVariableGuid|0x0|0|BS,NV,RT
   gNVIDIATokenSpaceGuid.PcdAcpiTimerEnabled|L"AcpiTimerEnabled"|gNVIDIAPublicVariableGuid|0x0|0|BS,NV
   gNVIDIATokenSpaceGuid.PcdUefiShellEnabled|L"UefiShellEnabled"|gNVIDIAPublicVariableGuid|0x0|0x01|BS,NV
diff --git a/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.c b/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.c
index c905f852..47506493 100644
--- a/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.c
+++ b/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.c
@@ -1172,7 +1172,7 @@ EFI_STATUS
 EFIAPI
 ProcessExtLinuxConfig (
   IN EFI_HANDLE             DeviceHandle,
-  IN UINT32                 BootChain,
+  IN L4T_BOOT_PARAMS        *BootParams,
   OUT EXTLINUX_BOOT_CONFIG  *BootConfig,
   OUT EFI_HANDLE            *RootFsHandle
   )
@@ -1185,6 +1185,12 @@ ProcessExtLinuxConfig (
   CHAR16           *Timeout      = NULL;
   CHAR16           *CbootArg     = NULL;
   CHAR16           *PostCbootArg = NULL;
+  CHAR16           *UEnvKernelImage = NULL;
+  CHAR16           *UEnvRamDiskImage = NULL;
+  CHAR16           *UEnvFDTDir = NULL;
+  CHAR16           *UEnvFDTFile = NULL;
+  CHAR16           *UEnvBootArgs = NULL;
+  CHAR16           *ConfPath = NULL;
   BOOLEAN          Ascii;
   UINTN            Index;
 
@@ -1194,21 +1200,28 @@ ProcessExtLinuxConfig (
     return EFI_INVALID_PARAMETER;
   }
 
-  Status = FindPartitionInfo (DeviceHandle, ROOTFS_BASE_NAME, BootChain, NULL, RootFsHandle);
+  Status = FindPartitionInfo (DeviceHandle, ROOTFS_BASE_NAME, BootParams->BootChain, NULL, RootFsHandle);
   if (EFI_ERROR (Status)) {
     ErrorPrint (L"%a: Unable to find partition info\r\n", __FUNCTION__);
     return Status;
   }
 
+  if (BootParams->BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+    ConfPath = UENV_CONF_PATH;
+  } else {
+    ConfPath = EXTLINUX_CONF_PATH;
+  }
+
   Status = OpenAndReadFileToBuffer (
              *RootFsHandle,
-             EXTLINUX_CONF_PATH,
+             ConfPath,
              &FileHandle,
              NULL,
              NULL
              );
+
   if (EFI_ERROR (Status)) {
-    ErrorPrint (L"%a:sds Failed to Authenticate %s (%r)\r\n", __FUNCTION__, EXTLINUX_CONF_PATH, Status);
+    ErrorPrint (L"%a:sds Failed to Authenticate %s (%r)\r\n", __FUNCTION__, ConfPath, Status);
     return Status;
   }
 
@@ -1225,6 +1238,63 @@ ProcessExtLinuxConfig (
 
     CleanLine = CleanExtLinuxLine (FileLine);
     if (*CleanLine != CHAR_NULL) {
+      if (BootParams->BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+        if ((BootParams->TorizonBootFlags & TORIZON_BOOTFLAGS_ROLLBACK) == 0) {
+          Status = CheckCommandString (CleanLine, UENV_KEY_KERNEL_IMAGE, &UEnvKernelImage);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_RAMDISK_IMAGE, &UEnvRamDiskImage);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_FDTDIR, &UEnvFDTDir);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_BOOTARGS, &UEnvBootArgs);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_FDTFILE, &UEnvFDTFile);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+        } else { /* (rollback enabled) */
+          Status = CheckCommandString (CleanLine, UENV_KEY_KERNEL_IMAGE2, &UEnvKernelImage);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_RAMDISK_IMAGE2, &UEnvRamDiskImage);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_FDTDIR2, &UEnvFDTDir);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_BOOTARGS2, &UEnvBootArgs);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+
+          Status = CheckCommandString (CleanLine, UENV_KEY_FDTFILE2, &UEnvFDTFile);
+          if (!EFI_ERROR (Status)) {
+            continue;
+          }
+        }
+
+        /* ignore ExtLinux config for Torizon boot */
+        continue;
+      }
+
       Status = CheckCommandString (CleanLine, EXTLINUX_KEY_TIMEOUT, &Timeout);
       if (!EFI_ERROR (Status)) {
         BootConfig->Timeout = StrDecimalToUintn (Timeout);
@@ -1297,6 +1367,22 @@ ProcessExtLinuxConfig (
     }
   }
 
+  if (BootParams->BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+    BootConfig->NumberOfBootOptions = 1;
+    BootConfig->BootOptions[0].LinuxPath = UEnvKernelImage;
+    BootConfig->BootOptions[0].InitrdPath = UEnvRamDiskImage;
+    BootConfig->BootOptions[0].BootArgs = UEnvBootArgs;
+    if (UEnvFDTDir != NULL && UEnvFDTFile != NULL) {
+      BootConfig->BootOptions[0].DtbPath = AllocatePool((StrLen(UEnvFDTDir) + StrLen(UEnvFDTFile) + 2) * sizeof (CHAR16));
+      if (BootConfig->BootOptions[0].DtbPath != NULL) {
+        BootConfig->BootOptions[0].DtbPath[0] = 0;
+        StrCatS (BootConfig->BootOptions[0].DtbPath, StrLen(UEnvFDTDir) + StrLen(UEnvFDTFile) + 2, UEnvFDTDir);
+        StrCatS (BootConfig->BootOptions[0].DtbPath, StrLen(UEnvFDTDir) + StrLen(UEnvFDTFile) + 2, L"/");
+        StrCatS (BootConfig->BootOptions[0].DtbPath, StrLen(UEnvFDTDir) + StrLen(UEnvFDTFile) + 2, UEnvFDTFile);
+      }
+    }
+  }
+
   if (FileLine != NULL) {
     FreePool (FileLine);
     FileLine = NULL;
@@ -1757,10 +1843,24 @@ ProcessBootParams (
 
   DataSize = sizeof (BootParams->BootMode);
   Status   = gRT->GetVariable (L4T_BOOTMODE_VARIABLE_NAME, &gNVIDIAPublicVariableGuid, NULL, &DataSize, &BootParams->BootMode);
-  if (EFI_ERROR (Status) || (BootParams->BootMode > NVIDIA_L4T_BOOTMODE_RECOVERY)) {
+
+  if (EFI_ERROR (Status) || (BootParams->BootMode > NVIDIA_L4T_BOOTMODE_TORIZON)) {
     BootParams->BootMode = NVIDIA_L4T_BOOTMODE_GRUB;
   }
 
+  if (BootParams->BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+    Status   = gRT->GetVariable (
+                      TORIZON_BOOTFLAGS_VARIABLE_NAME,
+                      &gNVIDIAPublicVariableGuid,
+                      NULL,
+                      &DataSize,
+                      &BootParams->TorizonBootFlags);
+    if (EFI_ERROR (Status)) {
+      ErrorPrint (L"Failed to read boot flags (err %r)\r\n", Status);
+      BootParams->TorizonBootFlags = 0;
+    }
+  }
+
   DataSize = sizeof (BootChain);
   Status   = gRT->GetVariable (BOOT_FW_VARIABLE_NAME, &gNVIDIAPublicVariableGuid, NULL, &DataSize, &BootChain);
   // If variable does not exist, is >4 bytes or has a value larger than 1, boot partition A
@@ -2646,10 +2746,14 @@ L4TLauncher (
       } while (FALSE);
     }
 
-    if (BootParams.BootMode == NVIDIA_L4T_BOOTMODE_DIRECT) {
-      ErrorPrint (L"%a: Attempting Direct Boot\r\n", __FUNCTION__);
+    if (BootParams.BootMode == NVIDIA_L4T_BOOTMODE_DIRECT || BootParams.BootMode == NVIDIA_L4T_BOOTMODE_TORIZON) {
+      if (BootParams.BootMode == NVIDIA_L4T_BOOTMODE_DIRECT) {
+        ErrorPrint (L"%a: Attempting Direct Boot\r\n", __FUNCTION__);
+      } else {
+        ErrorPrint (L"%a: Attempting Torizon Boot\r\n", __FUNCTION__);
+      }
       do {
-        Status = ProcessExtLinuxConfig (DeviceHandle, BootParams.BootChain, &ExtLinuxConfig, &RootFsDeviceHandle);
+        Status = ProcessExtLinuxConfig (DeviceHandle, &BootParams, &ExtLinuxConfig, &RootFsDeviceHandle);
         if (EFI_ERROR (Status)) {
           ErrorPrint (L"%a: Unable to process extlinux config: %r\r\n", __FUNCTION__, Status);
           BootParams.BootMode = NVIDIA_L4T_BOOTMODE_BOOTIMG;
diff --git a/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.h b/Silicon/NVIDIA/Application/L4TLauncher/L4TLauncher.h
