#!/bin/bash
# -*- mode: shell-script-mode; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*-

# Renesas (rz-community-bsp) is a special case among the vendor scripts: this
# flow runs *inside* the Renesas kas/Docker container (see
# docs/README-rzv2l.md - `./kas-container shell ...`), where kas has already
# created /build/conf/local.conf and /build/conf/bblayers.conf before this
# script ever runs. There is no `.repo` checkout and no normal
# OEROOT-relative layout here, so unlike every other vendor script this one
# does NOT call tdx_compute_oeroot / tdx_set_builddir / tdx_set_builddir_from_cwd
# / tdx_setup_path / tdx_setup_bb_env_passthrough - /build is a fixed,
# container-provided path, not something this script resolves itself. Do not
# "fix" this to be OEROOT/PWD-relative; that would break the kas flow.
#
# No integration-build (use-head-next) detection: this flow has no .repo
# manifest (kas/git-clone based), unlike stm32mp/nvidia/toradex which do have
# one - do not add this check here, it would silently never fire and adds
# false complexity.
#
# No EULA logic here: Renesas SDK licensing is handled elsewhere, not by this
# script.
#
# No $1/BUILDDIR positional-argument support: intentional, kas already fixes
# the build directory to /build.

# Explicit export, for BUILDDIR-blanking-fix consistency with the other 7
# vendor scripts, even though the value here is always the fixed /build path
# (there is no tdx_set_builddir*/-equivalent call to do this for us).
_TDX_BUILDDIR="/build"
BUILDDIR="/build"
export _TDX_BUILDDIR BUILDDIR

if tdx_needs_once /build/conf/local.conf "# Torizon"; then
  sed -i "/^MACHINE .*/c\MACHINE = '$MACHINE'" /build/conf/local.conf
  sed -i "/^DISTRO .*/c\DISTRO = '$DISTRO'" /build/conf/local.conf

  tdx_append_once /build/conf/local.conf "# Torizon" <<EOF
# Where to store sources
DL_DIR = "/build/downloads"

# Where to save shared state
SSTATE_DIR = "/build/sstate-cache"

# Where to save the build system work output
TMPDIR = "/build/tmp"

# Where to save the packages and images
DEPLOY_DIR = "/build/deploy"

# ease up disk space requirements
INHERIT += "rm_work"

# Torizon
include conf/machine/include/\${MACHINE}.inc
EOF
fi

tdx_append_once /build/conf/bblayers.conf "# Torizon" <<EOF
# Torizon
BBLAYERS += "\${TOPDIR}/../work/meta-toradex-torizon"
# Torizon deps
BBLAYERS += "\${TOPDIR}/../work/meta-updater"
BBLAYERS += "\${TOPDIR}/../work/meta-virtualization"
# meta-updater and meta-virtualization deps
BBLAYERS += "\${TOPDIR}/../work/meta-openembedded/meta-filesystems"
BBLAYERS += "\${TOPDIR}/../work/meta-openembedded/meta-python"
BBLAYERS += "\${TOPDIR}/../work/meta-openembedded/meta-networking"

OEROOT := "\${@os.path.abspath(os.path.dirname(d.getVar('FILE', True)))}/../.."
EOF

tdx_print_banner "Common Torizon OS" no
